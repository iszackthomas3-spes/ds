# Discord Bot Token - Required for Discord lookups
# Get this from https://discord.com/developers/applications
# 1. Create a new application
# 2. Go to the "Bot" section
# 3. Click "Add Bot"
# 4. Copy the token and paste it here
DISCORD_BOT_TOKEN=your_bot_token_here

# Note: For local development, replace 'your_bot_token_here' with your actual bot token
# For production on Vercel, set this in your project environment variables
